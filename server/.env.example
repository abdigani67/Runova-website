# --- Supabase ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service role key (server-side only, bypasses RLS — keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Meta / Instagram ---
# App Secret from the Meta app dashboard (used to verify X-Hub-Signature-256)
META_APP_SECRET=
# A string you choose; must match the token you enter in the Meta webhook setup UI
VERIFY_TOKEN=

# --- Server ---
# Optional. Railway sets PORT automatically; falls back to 3000 locally.
PORT=3000
